<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aipetbrain.mapper.PetShareLogMapper">

    <!-- 查询宠物的所有分享记录 -->
    <select id="selectLogsByPetId" resultType="com.aipetbrain.entity.PetShareLog">
        SELECT *
        FROM pet_share_log
        WHERE pet_id = #{petId}
        ORDER BY create_time DESC
    </select>

    <!-- 查询用户对某宠物的所有分享记录 -->
    <select id="selectLogsByPetIdAndUserId" resultType="com.aipetbrain.entity.PetShareLog">
        SELECT *
        FROM pet_share_log
        WHERE pet_id = #{petId} AND from_user_id = #{fromUserId}
        ORDER BY create_time DESC
    </select>

</mapper>

